<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/glass_card_bg"
    android:padding="12dp">

    <!-- Thumbnail Container -->
    <FrameLayout
        android:id="@+id/cart_row_thumb_container"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/cart_row_shoe_fill"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/shoe_sneaker_low_side_fill" />

        <ImageView
            android:id="@+id/cart_row_shoe_details"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/shoe_sneaker_low_side_details" />
    </FrameLayout>

    <!-- Shoe details -->
    <TextView
        android:id="@+id/cart_row_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Air Runner 2"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/cart_row_thumb_container"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Variant descriptors -->
    <TextView
        android:id="@+id/cart_row_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:text="Color: Coral | Size: 9 | Qty: 1"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        app:layout_constraintStart_toEndOf="@id/cart_row_thumb_container"
        app:layout_constraintTop_toBottomOf="@id/cart_row_name" />

    <!-- Subtotal Price -->
    <TextView
        android:id="@+id/cart_row_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:text="$89.99"
        android:textColor="@color/coral_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/cart_row_thumb_container"
        app:layout_constraintTop_toBottomOf="@id/cart_row_details" />

    <!-- Delete Item Button -->
    <ImageButton
        android:id="@+id/btn_delete_cart_row"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_delete"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_secondary" />

</androidx.constraintlayout.widget.ConstraintLayout>
