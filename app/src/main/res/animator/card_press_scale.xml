<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Touch/Pressed state: scale up and increase elevation slightly for premium feel -->
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="80"
                android:valueTo="1.03"
                android:valueType="floatType"/>
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="80"
                android:valueTo="1.03"
                android:valueType="floatType"/>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="80"
                android:valueTo="8dp"
                android:valueType="floatType"/>
        </set>
    </item>
    <!-- Default state: smooth return to standard dimensions -->
    <item>
        <set>
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="120"
                android:valueTo="1.0"
                android:valueType="floatType"/>
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="120"
                android:valueTo="1.0"
                android:valueType="floatType"/>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="120"
                android:valueTo="0dp"
                android:valueType="floatType"/>
        </set>
    </item>
</selector>
