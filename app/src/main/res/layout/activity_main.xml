<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_peach"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!-- WELCOME / IDLE CONTAINER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container_welcome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible"
        tools:visibility="gone">

        <!-- Kiosk Header -->
        <TextView
            android:id="@+id/text_brand_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/app_name"
            android:textColor="@color/coral_primary"
            android:textSize="36sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/text_welcome_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/welcome_subheading"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_brand_title" />

        <!-- Giant Glassmorphic Welcome Card -->
        <FrameLayout
            android:id="@+id/welcome_card_frame"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/glass_card_bg"
            app:layout_constraintBottom_toTopOf="@id/btn_start_ordering"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_welcome_desc">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="32dp">

                <!-- Promotional Shoe Fill -->
                <ImageView
                    android:id="@+id/welcome_shoe_fill"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/shoe_sneaker_low_side_fill"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/coral_light" />

                <!-- Promotional Shoe Outline Details -->
                <ImageView
                    android:id="@+id/welcome_shoe_details"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/shoe_sneaker_low_side_details"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Call to action inside card -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap below to configure and order"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="italic"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>

        <!-- Tap to Start Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_ordering"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="40dp"
            android:text="@string/start_order"
            android:textSize="20sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- TRAVELING / ARRIVED ROBOT STATUS PANEL -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container_travel_status"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Heavy Glassmorphic Card for Robot State -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.85">

            <!-- Status Indicator Icon -->
            <ProgressBar
                android:id="@+id/progress_robot_travel"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:indeterminateTint="@color/coral_primary" />

            <ImageView
                android:id="@+id/img_status_arrived"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_dialog_info"
                android:visibility="gone"
                app:tint="@color/coral_primary" />

            <!-- Title: Arrived / Heading to -->
            <TextView
                android:id="@+id/text_status_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/status_traveling_storeroom"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Subtitle/Instructions -->
            <TextView
                android:id="@+id/text_status_instructions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Please wait while Temi travels to the store room..."
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <!-- Order Items Header Title -->
            <TextView
                android:id="@+id/text_order_items_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Items to Collect:"
                tools:visibility="visible" />

            <!-- Order Items Preview Container (inflated dynamically) -->
            <LinearLayout
                android:id="@+id/layout_order_items_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Action Confirm Button (OK) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_status_ok"
                android:layout_width="240dp"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="@string/button_ok"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="12dp"
                tools:visibility="visible" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
